# GitHub fine-grained personal access token
# Required permissions: Contents -> Read and Write on your profile repo
GITHUB_TOKEN=github_pat_...

# Your profile repository, format: username/username
GITHUB_REPO=yourusername/yourusername

# Port the local server listens on
SERVER_PORT=8000

# Shared secret between server and Tampermonkey script
# Generate one with: openssl rand -hex 24
API_SECRET=your_secret_here
